# Copy this file to .env (for `vercel dev`) and fill in real values.
# Never commit .env or real secret keys.

# Stripe Dashboard -> Developers -> API keys -> Secret key
STRIPE_SECRET_KEY=sk_test_...

# Stripe Dashboard -> Developers -> Webhooks -> your endpoint -> Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Your deployed site origin, no trailing slash (used to build Stripe redirect URLs).
# Safe to leave unset locally — the API falls back to the request's own host.
SITE_URL=https://your-site.vercel.app

# Password for the /admin product-catalog editor.
ADMIN_PASSWORD=choose-something

# Only needed once you've connected an Edge Config store (see README ->
# "Editing the product catalog") so the admin page can save changes.
# EDGE_CONFIG is set automatically by Vercel when you link the store.
VERCEL_API_TOKEN=
EDGE_CONFIG_ID=ecfg_...
VERCEL_TEAM_ID=

# Only needed once you've connected a Blob store (see README -> "Product
# photos") so the admin page can upload product images.
# BLOB_READ_WRITE_TOKEN is set automatically by Vercel when you link the store.

# Only needed once you've connected a Redis store (see README -> "Order
# tracking and fulfilling orders") so orders persist and can be tracked.
# REDIS_URL is set automatically by Vercel when you link the store.
REDIS_URL=

# Optional: a Slack Incoming Webhook URL to post new orders to a channel.
SLACK_WEBHOOK_URL=

# Optional: Resend API key to send a PURE-branded order confirmation email
# to guests (see README -> "Order confirmation email"). Without it, guests
# just don't get this email (Stripe's own receipt toggle is separate).
RESEND_API_KEY=

# Optional: sender address once you've verified your own domain in Resend.
# Defaults to Resend's shared onboarding@resend.dev if unset.
EMAIL_FROM=
